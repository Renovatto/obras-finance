@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
	body {
		@apply bg-gray-50 text-gray-900 antialiased;
		/* Previne behaviours default que atrapalham PWAs e mobile view */
		-webkit-touch-callout: none;
		-webkit-user-select: none;
		user-select: none;
	}

	/* Permite scroll mas esconde a navbar mobile em edge cases */
	.pb-safe {
		padding-bottom: env(safe-area-inset-bottom, 16px);
	}
	.pt-safe {
		padding-top: env(safe-area-inset-top, 16px);
	}
}
